{
  "name": "atmospheric",
  "version": "0.2.0",
  "license": "MIT",
  "dependencies": [
    "glad",
    "glm",
    {
      "name": "bullet3",
      "features": [
        "multithreading"
      ]
    },
    "fmt",
    "spdlog",
    "tinygltf",
    "tracy",
    "rmlui",
    "box2d",
    "flatbuffers",
    {
      "name": "curl",
      "features": ["http2", "openssl"],
      "platform": "!emscripten"
    },
    {
      "name": "libwebsockets",
      "features": ["openssl"],
      "platform": "!emscripten"
    }
  ]
}
