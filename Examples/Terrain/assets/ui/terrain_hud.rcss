body {
    font-family: Noto Sans;
    font-size: 15dp;
    color: #f0f0f0;
    width: 100%;
    height: 100%;
}

#panel {
    position: absolute;
    top: 12dp;
    left: 12dp;
    width: 210dp;
    padding: 10dp;
    background-color: #101018d2;
    border-radius: 8dp;
    border-width: 1dp;
    border-color: #2a2a3a;
}

.title {
    font-size: 18dp;
    color: #ffffff;
    margin-bottom: 8dp;
}

.label {
    font-size: 12dp;
    color: #9a9aa8;
    margin-bottom: 3dp;
}

.hint {
    margin-top: 10dp;
    font-size: 11dp;
    color: #70707e;
}

/* Toggle button */
.btn {
    display: block;
    padding: 7dp 8dp;
    margin-bottom: 10dp;
    text-align: center;
    color: #e6e6ee;
    background-color: #22283ae6;
    border-radius: 5dp;
    border-width: 1dp;
    border-color: #38405a;
    cursor: pointer;
    white-space: nowrap;
    overflow: hidden;
}
.btn:hover {
    background-color: #2e3550e6;
    border-color: #58aaff;
}

/* Dropdown */
.dropdown {
    position: relative;
}

.dd_current {
    position: relative;
    padding: 7dp 22dp 7dp 8dp;   /* right padding leaves room for the caret */
    color: #e6e6ee;
    background-color: #22283ae6;
    border-radius: 5dp;
    border-width: 1dp;
    border-color: #38405a;
    cursor: pointer;
    white-space: nowrap;
    overflow: hidden;
}
.dd_current:hover {
    border-color: #58aaff;
}

/* Absolutely positioned so it never affects the label's line box (avoids the
   float-collapse / wrap issues that shifted layout on longer palette names). */
.caret {
    position: absolute;
    top: 7dp;
    right: 8dp;
    color: #8a8a9a;
}

.dd_list {
    display: none;
    margin-top: 3dp;
    background-color: #161a28f2;
    border-radius: 5dp;
    border-width: 1dp;
    border-color: #38405a;
}
#palette_dd.open .dd_list {
    display: block;
}

.dd_item {
    display: block;
    padding: 6dp 8dp;
    font-size: 13dp;
    color: #b8b8c8;
    cursor: pointer;
    white-space: nowrap;
    overflow: hidden;
}
.dd_item:hover {
    background-color: #2a3350e6;
    color: #ffffff;
}
.dd_item.sel {
    color: #ffffff;
    background-color: #2a3a55e6;
}
