<rml>
<head>
    <title>Loading</title>
    <style>
        body {
            width: 100%;
            height: 100%;
            margin: 0px;
            padding: 0px;
            background-color: #000000;
            opacity: 0;
            transition: opacity 0.4s ease-in-out;
        }
        body.visible {
            opacity: 1;
        }
    </style>
</head>
<body id="loading-screen">
</body>
</rml>
