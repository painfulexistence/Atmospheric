Checks: >
  readability-identifier-naming,
  readability-avoid-const-params-in-decls,
  readability-function-cognitive-complexity,
  modernize-use-auto,
  modernize-use-nullptr,
  modernize-use-override,
  bugprone-use-after-move,
  bugprone-dangling-handle,
  performance-unnecessary-copy-initialization,
  performance-move-const-arg,
  google-readability-casting,
  cppcoreguidelines-virtual-class-destructor,
  cppcoreguidelines-special-member-functions,
  -readability-magic-numbers,
  -readability-braces-around-statements,
  -readability-misleading-indentation

CheckOptions:
  # cppcoreguidelines-special-member-functions: allow Rule of Zero — classes
  # whose members already handle everything don't need the full five spelled out.
  cppcoreguidelines-special-member-functions.AllowSoleDefaultDtor: true
  cppcoreguidelines-special-member-functions.AllowMissingMoveFunctionsWhenCopyIsDeleted: true
  readability-identifier-naming.ClassCase: CamelCase
  readability-identifier-naming.TypeCase: CamelCase
  readability-identifier-naming.EnumCase: CamelCase
  readability-identifier-naming.EnumConstantCase: CamelCase
  readability-identifier-naming.FunctionCase: CamelCase
  readability-identifier-naming.MethodCase: CamelCase
  readability-identifier-naming.MemberCase: camelBack
  readability-identifier-naming.PrivateMemberPrefix: _
  readability-identifier-naming.VariableCase: camelBack
  readability-identifier-naming.ParameterCase: camelBack
  readability-identifier-naming.NamespaceCase: CamelCase
